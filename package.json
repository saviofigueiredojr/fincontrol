{
    "name": "fincontrol",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": "22.x"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "rm -rf .next/types && tsc --noEmit",
        "db:push": "prisma db push",
        "db:seed": "npx tsx prisma/seed.ts",
        "db:studio": "prisma studio",
        "telegram:sync": "npx tsx scripts/telegram-sync.ts",
        "generate": "prisma generate",
        "postinstall": "prisma generate",
        "vercel-build": "prisma generate && prisma migrate deploy && next build",
        "ci": "npm run generate && npm run typecheck && npm run test && npm run build"
    },
    "dependencies": {
