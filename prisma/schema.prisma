generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Household {
  id                 String              @id @default(cuid())
  name               String
  users              User[]
  goals              Goal[]
  monthCloses        MonthClose[]
  recurringTemplates RecurringTemplate[]
  settings           Setting[]
  pjReceipts         PjReceipt[]
  createdAt          DateTime            @default(now())
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("member") // admin | member
  householdId  String
  household    Household     @relation(fields: [householdId], references: [id])
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  creditCards  CreditCard[]
  pjReceipts   PjReceipt[]

  @@index([householdId])
}

model Transaction {
  id                 String         @id @default(cuid())
  date               DateTime
  competencia        String // YYYY-MM (mês de competência)
  description        String
  category           String
  amount             Float // sempre positivo
  type               String // income | expense | transfer
  ownership          String // mine | partner | joint
  isSecret           Boolean        @default(false) // oculta do parceiro
  isRecurring        Boolean        @default(false)
  recurringId        String? // agrupa recorrentes
  installmentCurrent Int? // parcela atual (1, 2, 3...)
  installmentTotal   Int? // total de parcelas
  parentId           String? // ID da transação original (parcelas)
  source             String? // manual | csv_inter | ofx | recurring
  cardStatementId    String?
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  cardStatement      CardStatement? @relation(fields: [cardStatementId], references: [id])
  pjReceipt          PjReceipt?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([competencia])
  @@index([userId])
  @@index([ownership])
  @@index([parentId])
}

model CreditCard {
  id         String          @id @default(cuid())
  name       String // "Inter", "Nubank", etc.
  bank       String
  closingDay Int // dia de fechamento da fatura
  dueDay     Int // dia de vencimento
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  statements CardStatement[]
  createdAt  DateTime        @default(now())
}

model CardStatement {
  id           String        @id @default(cuid())
  cardId       String
  competencia  String // YYYY-MM
  totalAmount  Float
  status       String        @default("open") // open | paid
  card         CreditCard    @relation(fields: [cardId], references: [id])
  transactions Transaction[]
  createdAt    DateTime      @default(now())

  @@unique([cardId, competencia])
}

model MonthClose {
  id             String    @id @default(cuid())
  competencia    String // YYYY-MM
  householdId    String
  household      Household @relation(fields: [householdId], references: [id])
  openingBalance Float
  totalIncome    Float
  totalExpense   Float
  metaAllocation Float     @default(0)
  closingBalance Float
  status         String    @default("open") // open | closed
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([householdId, competencia])
}

model Goal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  householdId   String
  household     Household @relation(fields: [householdId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([householdId])
}

model RecurringTemplate {
  id          String  @id @default(cuid())
  description String
  category    String
  amount      Float
  type        String // income | expense
  ownership   String // mine | partner | joint
  dayOfMonth  Int // dia do mês para lançar
  startDate   String // YYYY-MM
  endDate     String? // YYYY-MM (null = indefinido)

  // Projection features
  interval      String  @default("monthly") // monthly | yearly
  intervalCount Int     @default(1)
  isVariable    Boolean @default(false)

  isActive    Boolean   @default(true)
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([householdId])
}

model Setting {
  id          String    @id @default(cuid())
  key         String
  value       String
  householdId String
  household   Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, key])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ip        String?
  createdAt DateTime @default(now())

  @@index([email, ip, createdAt])
}

model PjReceipt {
  id            String       @id @default(cuid())
  clientName    String
  description   String
  amount        Float
  dueDate       DateTime
  status        String       @default("unissued") // unissued, issued, pending, paid
  competencia   String // YYYY-MM
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  householdId   String
  household     Household    @relation(fields: [householdId], references: [id])
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([householdId])
}
